# Copy to apps/api/.env (or add the same keys to the monorepo root .env).
# Without SMTP_USER + SMTP_PASS, OTP is NOT sent by email in development —
# the API returns devOtp in the JSON response and logs [DEV OTP] to the console.

PORT=3001
DATABASE_URL="postgresql://user:password@localhost:5432/codeforces?schema=public"
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"
NODE_ENV=development

# Required for real email in all environments you expect mail (production: mandatory at API boot).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Codeforces <noreply@yourdomain.com>"

# Interview (/api/interview): Mistral for STT + grading (server-only; never NEXT_PUBLIC_*).
MISTRAL_API_KEY=
# MISTRAL_CHAT_MODEL=mistral-small-latest
# MISTRAL_TRANSCRIBE_MODEL=voxtral-mini-latest
# Production: set INTERVIEW_ENABLED=true to expose interview routes.
